PORT=3001
CLIENT_ORIGIN=http://localhost:8081,http://127.0.0.1:8081,http://localhost:8082,http://127.0.0.1:8082
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lazyde
LOG_LEVEL=info
JWT_SECRET=

# 高德 Web 服务 Key：用于后端把本地地点名称解析为经纬度并计算真实距离
AMAP_WEB_SERVICE_KEY=

# 邮箱验证码：本地默认 mock，会在非生产环境返回 devCode
EMAIL_PROVIDER=mock

# QQ 邮箱验证码：把 EMAIL_PROVIDER 改为 qq，并填 QQ 邮箱 SMTP 授权码（不是 QQ 登录密码）
# QQ 邮箱设置入口：设置 -> 账号 -> POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV 服务 -> 开启 SMTP 并生成授权码
# EMAIL_PROVIDER=qq
# QQ_EMAIL=user@example.com
# QQ_SMTP_AUTH_CODE=
# SMTP_FROM_NAME=懒得出门

# 通用 SMTP：如不用 QQ，可使用以下配置
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@example.com
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
# SMTP_FROM_NAME=懒得出门

# 旧短信验证码配置：当前登录入口已切换为邮箱验证码，以下配置暂不用于登录
SMS_PROVIDER=mock
# 腾讯云短信：需要先在腾讯云短信控制台创建应用、签名、正文模板并通过审核
# SecretId / SecretKey 建议使用只授予短信发送权限的 CAM 子账号
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
# 模板变量顺序：只包含验证码用 code；如果模板含“有效分钟数”变量，用 code,ttlMinutes
TENCENT_SMS_TEMPLATE_PARAMS=code
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_ENDPOINT=sms.tencentcloudapi.com

# 支付宝沙箱：会员月卡支付
# 新版沙箱网关默认使用 https://openapi-sandbox.dl.alipaydev.com/gateway.do
# 如果你的沙箱控制台仍是老环境，可手动设置 ALIPAY_GATEWAY=https://openapi.alipaydev.com/gateway.do
# 生产环境把 ALIPAY_ENV 改为 production
ALIPAY_ENV=sandbox
ALIPAY_APP_ID=
# 推荐使用文件路径，避免 .env 多行私钥转义问题；路径相对 apps/api 目录
ALIPAY_PRIVATE_KEY_PATH=./certs/alipay-sandbox-app-private-key.pem
ALIPAY_PUBLIC_KEY_PATH=./certs/alipay-sandbox-public-key.pem
# 如果你直接填密钥文本，使用 \\n 表示换行；不要把真实密钥提交到 Git
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
ALIPAY_KEY_TYPE=PKCS8
# 本地调试如果支付宝无法回调 localhost，可先依赖支付返回后的后端查单；生产必须配置公网 HTTPS notifyUrl
# ALIPAY_NOTIFY_URL=https://你的公网域名/api/v1/payments/alipay/notify
ALIPAY_VIP_MONTH_AMOUNT_YUAN=18

# 推荐：硅基流动 + DeepSeek-V4-Pro（国内访问稳定）
AI_LLM_PROVIDER=siliconflow
AI_EMBEDDING_PROVIDER=siliconflow
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_LLM_MODEL=deepseek-ai/DeepSeek-V4-Pro
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
# QDRANT_URL=http://127.0.0.1:6333

# 或使用 OpenAI / 智谱 / DeepSeek 官方
# OPENAI_API_KEY=
# AI_LLM_PROVIDER=openai
# AI_EMBEDDING_PROVIDER=openai
# ZHIPU_API_KEY=
# DEEPSEEK_API_KEY=
# DEEPSEEK_LLM_MODEL=deepseek-v4-pro
