# Web 与 iOS 模拟器可使用 localhost；Android 模拟器请改为 10.0.2.2。
# 真机调试时填写开发机可被手机访问的局域网地址。
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1

# 高德地图 JS API（Web 端地图画布）
# 在高德开放平台申请 Web 端（JS API）Key；2021-12-02 后申请的 Key 通常还需要安全密钥。
EXPO_PUBLIC_AMAP_JS_KEY=
EXPO_PUBLIC_AMAP_SECURITY_JS_CODE=
# 生产环境建议按高德文档走服务端代理，并配置形如 https://example.com/_AMapService 的地址。
EXPO_PUBLIC_AMAP_SERVICE_HOST=
