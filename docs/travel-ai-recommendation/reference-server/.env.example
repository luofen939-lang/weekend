PORT=3002
NODE_ENV=development

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=travel_ai

# JWT
JWT_SECRET=

# Redis（可选，未配置时使用内存缓存）
# REDIS_URL=redis://127.0.0.1:6379

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_ATTRACTIONS=attractions
QDRANT_COLLECTION_DESTINATIONS=destinations
QDRANT_COLLECTION_USERS=users

# AI Provider: openai | zhipu | deepseek
AI_EMBEDDING_PROVIDER=openai
AI_LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_DIMENSIONS=1536

# 智谱（可选）
ZHIPU_API_KEY=
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_LLM_MODEL=glm-4-flash

# DeepSeek（可选）
DEEPSEEK_API_KEY=
DEEPSEEK_LLM_MODEL=deepseek-chat

# 推荐缓存 TTL（秒）
RECOMMEND_CACHE_TTL=900
